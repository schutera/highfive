# Copy to .deploy.env (chmod 600) and fill in. Sourced by scripts/deploy.sh.
# .deploy.env is gitignored — never commit the real webhook.

# Discord webhook for deploy notifications (success / fail / fleet-OTA).
# Leave unset to have notifications log locally to logs/auto-deploy.log only;
# the deploy itself still runs.
DISCORD_WEBHOOK_URL=

# Autonomous, test-gated firmware OTA. When 1, a firmware-source change on the
# deploy branch (production — or an in-tree SEQUENCE ahead of what's served)
# triggers: native test gate
# (pio test -e native) -> build.sh -> publish OTA -> bump/commit/push/tag.
# Forward-only: once a good manifest publishes the fleet pulls it and there is
# NO field rollback. Set 0 to deploy services only and never touch firmware.
FIRMWARE_AUTO_OTA=1

# Optional. If unset, ESP32-CAM/build.sh reads the gitignored ESP32-CAM/GEO_API_KEY
# file (already present on the prod host).
# GEO_API_KEY=
