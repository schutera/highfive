# HighFive Production Environment Variables
# Copy this file to .env and fill in your production values
# ⚠️ NEVER commit the .env file to version control!

# Admin secret (login password + session-cookie HMAC key; #142 / ADR-019).
# Generate a secure key: openssl rand -base64 32
# Never shipped to the browser. Rotating it invalidates outstanding sessions.
HIGHFIVE_API_KEY=your_secure_production_key_here

# NOTE: VITE_API_KEY was removed (#142) — the homepage bundle carries no
# secret. Reads are public; admin actions use the server-side session cookie.

# API URL (used by frontend)
# Point to your production API domain
VITE_API_URL=https://api.highfive.schutera.com

# Node environment
NODE_ENV=production

# Backend port (internal)
PORT=3001
