# Production environment for docker-compose.prod.yml
# Copy this to .env.production, fill in the secrets, and run:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# `docker compose` will FAIL FAST if any of these are unset or empty.
# This is by design - it replaces the silent dev-key fallback that
# shipped before fix/prod-stack-secrets-and-topology (#37).

# Admin secret. Generate with: openssl rand -base64 32
# This is the admin LOGIN PASSWORD (POST /api/admin/login) and the HMAC key
# that signs admin session cookies. Rotating it invalidates outstanding
# sessions. It is NEVER shipped to the browser (#142 / ADR-019).
HIGHFIVE_API_KEY=

# NOTE: VITE_API_KEY was removed (#142). The homepage bundle no longer carries
# any secret — a single-page app cannot hold one. Reads are public; admin
# actions authenticate via the server-side session cookie above.
