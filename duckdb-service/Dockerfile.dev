# Python floor — must match /.python-version (3.10); guarded by 'make check-python-version' (#197, ADR-029).
FROM python:3.10-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV DUCKDB_PATH=/data/app.duckdb

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# DB-Verzeichnis vorbereiten
RUN mkdir -p /data

EXPOSE 8000

CMD ["python", "app.py"]