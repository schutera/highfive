# homepage/Dockerfile.dev
#
# Build context is the repo root (see docker-compose.yml). Same
# workspace setup as backend/Dockerfile.dev — see that file for the
# rationale.
FROM node:22-alpine

WORKDIR /app

# `.npmrc` carries `engine-strict=true` (see ADR-009).
COPY package.json package-lock.json .npmrc ./
COPY contracts/package.json ./contracts/package.json
COPY backend/package.json ./backend/package.json
COPY homepage/package.json ./homepage/package.json

RUN npm ci

COPY contracts ./contracts
COPY homepage ./homepage

WORKDIR /app/homepage

EXPOSE 5173
ENV NODE_ENV=development

CMD ["npm", "run", "dev", "--", "--host"]
