FROM python:3.12-slim

WORKDIR /app

# opencv-python-headless (hole detection, #165) still links libglib at import
# time; the GUI/GL libs are what `headless` drops, not glib. Without this the
# container builds fine but `import cv2` fails at runtime with
# "libgthread-2.0.so.0: cannot open shared object file".
RUN apt-get update \
    && apt-get install -y --no-install-recommends libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN mkdir -p /data/images

EXPOSE 4444

CMD ["python", "app.py"]
